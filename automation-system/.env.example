# =====================================================
# UPJ ダッシュボード 環境変数設定
# このファイルをコピーして .env にリネームして使う
# .env は絶対にGitにコミットしない
# =====================================================

# ── AI ────────────────────────────────────────────
# https://console.anthropic.com/ で取得
ANTHROPIC_API_KEY=

# ── ダッシュボード認証 ──────────────────────────────
DASHBOARD_PASSWORD=            # 設定するとログイン画面が有効（空なら認証スキップ）
FLASK_SECRET_KEY=              # セッション署名キー（空なら起動時自動生成）
FLASK_DEBUG=false              # true にすると Flask デバッグモード有効

# ── 共通設定 ──────────────────────────────────────
DRY_RUN=false                  # true にすると実際に投稿せずログだけ出る（テスト用）
OWNER_LINE_USER_ID=            # 朝のサマリー受信用（自分のLINE user_id）
NOTIFY_EMAIL=                  # エスカレーション通知先メール

# ════════════════════════════════════════════════════
# ── UPJ（Universal Planet Japan）────────────────────
# ════════════════════════════════════════════════════

# Instagram（Meta Graph API）
# Meta for Developers > アプリ > アクセストークン
UPJAPAN_META_ACCESS_TOKEN=
UPJAPAN_INSTAGRAM_ACCOUNT_ID=     # IG ビジネスアカウントの数値ID

# Threads（Meta Threads API）
UPJAPAN_THREADS_USER_ID=          # Threads ユーザーID（IG と同じ場合もある）

# Facebook ページ
UPJAPAN_FB_PAGE_ID=
UPJAPAN_FB_PAGE_TOKEN=

# Twitter / X
UPJAPAN_TWITTER_API_KEY=
UPJAPAN_TWITTER_API_SECRET=
UPJAPAN_TWITTER_ACCESS_TOKEN=
UPJAPAN_TWITTER_ACCESS_SECRET=

# WordPress
UPJAPAN_WP_URL=https://upjapan.co.jp
UPJAPAN_WP_USER=
UPJAPAN_WP_APP_PASSWORD=          # 管理画面 > ユーザー > プロフィール > アプリパスワード

# Google Analytics 4
UPJAPAN_GA4_PROPERTY_ID=          # 例: 123456789
# Google Search Console
UPJAPAN_GSC_SITE_URL=https://upjapan.co.jp/

# ════════════════════════════════════════════════════
# ── DSc Marketing ───────────────────────────────────
# ════════════════════════════════════════════════════

DSC_MARKETING_META_ACCESS_TOKEN=
DSC_MARKETING_INSTAGRAM_ACCOUNT_ID=
DSC_MARKETING_THREADS_USER_ID=

DSC_MARKETING_FB_PAGE_ID=
DSC_MARKETING_FB_PAGE_TOKEN=

DSC_MARKETING_TWITTER_API_KEY=
DSC_MARKETING_TWITTER_API_SECRET=
DSC_MARKETING_TWITTER_ACCESS_TOKEN=
DSC_MARKETING_TWITTER_ACCESS_SECRET=

# YouTube（DSc Marketing チャンネル）
# Google Cloud Console > YouTube Data API v3 > OAuth2
# credentials.json を automation-system/ に配置
DSC_MARKETING_YOUTUBE_CHANNEL_ID=

# TikTok（DSc Marketing）
# TikTok for Developers > アプリ > アクセストークン
DSC_MARKETING_TIKTOK_ACCESS_TOKEN=

# LINE（DSc Marketing）
# LINE Developers > チャネル > Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# WordPress
DSC_MARKETING_WP_URL=https://dsc-marketing.com
DSC_MARKETING_WP_USER=
DSC_MARKETING_WP_APP_PASSWORD=

# Google Analytics 4
DSC_MARKETING_GA4_PROPERTY_ID=
# Google Search Console
DSC_MARKETING_GSC_SITE_URL=https://dsc-marketing.com/

# ════════════════════════════════════════════════════
# ── cashflowsupport ─────────────────────────────────
# ════════════════════════════════════════════════════

CASHFLOWSUPPORT_META_ACCESS_TOKEN=
CASHFLOWSUPPORT_INSTAGRAM_ACCOUNT_ID=

# LINE（cashflowsupport）
LINE_CHANNEL_ACCESS_TOKEN_CSF=
LINE_CHANNEL_SECRET_CSF=

# WordPress
CASHFLOWSUPPORT_WP_URL=https://cashflowsupport.jp
CASHFLOWSUPPORT_WP_USER=
CASHFLOWSUPPORT_WP_APP_PASSWORD=

# Google Analytics 4
CASHFLOWSUPPORT_GA4_PROPERTY_ID=
# Google Search Console
CASHFLOWSUPPORT_GSC_SITE_URL=https://cashflowsupport.jp/

# ════════════════════════════════════════════════════
# ── Google 共通 ─────────────────────────────────────
# ════════════════════════════════════════════════════
# サービスアカウントの credentials.json を automation-system/ に配置
# Google Drive（ナノバナナプロの素材書き出し先フォルダID）
GOOGLE_DRIVE_FOLDER_ID=

# ════════════════════════════════════════════════════
# ── Google Business Profile (MEO) ───────────────────
# ════════════════════════════════════════════════════
# 方法A: OAuth2 リフレッシュトークン（推奨）
#   1. Google Cloud Console でプロジェクト作成
#   2. My Business API を有効化（Business Profile API）
#   3. OAuth2 認証情報を作成（デスクトップアプリ）
#   4. 下記スコープで認可: https://www.googleapis.com/auth/business.manage
#   5. refresh_token を取得して設定
GBP_CLIENT_ID=
GBP_CLIENT_SECRET=
GBP_REFRESH_TOKEN=
# 方法B: サービスアカウント（JSON文字列 or ファイルパス）
# GBP_SERVICE_ACCOUNT_JSON=
# オプション: アカウント名を固定する場合（例: accounts/123456789）
# GBP_ACCOUNT_NAME=

# ════════════════════════════════════════════════════
# ── Satoshi Life Blog（個人ブログ）──────────────────
# ════════════════════════════════════════════════════
SATOSHI_BLOG_WP_URL=https://satoshi-life.site
SATOSHI_BLOG_WP_USER=
SATOSHI_BLOG_WP_APP_PASSWORD=    # 管理画面 > ユーザー > プロフィール > アプリパスワード

